# Core app
SECRET_KEY=replace-with-a-long-random-secret
UPLOAD_FOLDER=uploads/credits

# Primary database (required): cloud Postgres used for both
# - ERP mirror reads (populated by beisser-api)
# - WH-Tracker app writes (pick/pickster/pick_assignments/audit/work-orders/etc)
DATABASE_URL=
CLOUD_MODE=true

# Optional: temporary break-glass direct ERP fallback (disabled by default)
ENABLE_LEGACY_ERP_FALLBACK=false
SQLSERVER_DSN=
SQLSERVER_SERVER=
SQLSERVER_DB=AgilitySQL
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server

# ERP mirror sync worker
TRACKER_BASE_URL=http://127.0.0.1:5000
SYNC_INTERVAL_SECONDS=5
SYNC_CHANGE_MONITORING=true
SYNC_WORKER_NAME=erp-sync
SYNC_WORKER_MODE=pi
SYNC_HEARTBEAT_INTERVAL_SECONDS=5
SYNC_MASTER_CADENCE_SECONDS=300
SYNC_OPERATIONAL_CADENCE_SECONDS=5
SYNC_AR_CADENCE_SECONDS=300
SYNC_DOCUMENT_CADENCE_SECONDS=300
SYNC_BATCH_SIZE=1000
MIRROR_STAGING_SCHEMA=public
DB_USE_NULL_POOL=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300

# Dispatch / GPS enrichment
GPS_CSV_PATH=
LOGO_PATH=

# Samsara
SAMSARA_API_TOKEN=
SAMSARA_CACHE_TTL=15
SAMSARA_BRANCH_TAGS_JSON={}
SAMSARA_VEHICLE_BRANCH_MAP={}

# Credit image / email sync
EMAIL_ADDRESS=
EMAIL_PASSWORD=
IMAP_SERVER=outlook.office365.com
IMAP_PORT=993
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=

# ---------------------------------------------------------------------------
# Authentication (passwordless email OTP)
# ---------------------------------------------------------------------------

# Set true to require login on ALL routes.  false = auth system is built but
# not enforced (useful while seeding users / testing).
AUTH_REQUIRED=false

# OTP email delivery — pick ONE method:
#
# Option A (recommended): Resend API  →  just set this one var
RESEND_API_KEY=
#
# Option B: Generic SMTP (Office 365, Gmail, etc.)
OTP_SMTP_SERVER=smtp.office365.com
OTP_SMTP_PORT=587
OTP_SMTP_USER=          # defaults to OTP_EMAIL_FROM; set to "resend" for Resend SMTP relay
OTP_EMAIL_FROM=
OTP_EMAIL_PASSWORD=

# App name shown in the OTP email subject & body
OTP_APP_NAME=Beisser Ops

# DEV ONLY: print OTP to console instead of sending email (never use in prod)
AUTH_OTP_CONSOLE=false

# Session cookie security (auto-enabled on Vercel/Fly)
SESSION_COOKIE_SECURE=false

# Phase 2 — SMS OTP via Twilio (leave blank until ready)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
