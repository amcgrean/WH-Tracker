# Core app
SECRET_KEY=replace-with-a-long-random-secret
UPLOAD_FOLDER=uploads/credits

# Local / on-prem ERP SQL access
# Preferred: DSN
SQLSERVER_DSN=

# Explicit SQL fallback
SQLSERVER_SERVER=
SQLSERVER_DB=AgilitySQL
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server

# Legacy fallback names still supported
SQL_HOST=
SQL_PORT=1433
SQL_DB=AgilitySQL
SQL_USER=
SQL_PASSWORD=
ODBC_DRIVER=ODBC Driver 17 for SQL Server

# Tracker runtime mode
CLOUD_MODE=false
DATABASE_URL=
CENTRAL_DB_URL=
TRACKER_LEGACY_DB_URL=
# During full Supabase cutover, CENTRAL_DB_URL can be left blank and will fall back to DATABASE_URL.

# ERP mirror sync worker
TRACKER_BASE_URL=http://127.0.0.1:5000
SYNC_INTERVAL_SECONDS=5
SYNC_CHANGE_MONITORING=true
SYNC_WORKER_NAME=erp-sync
SYNC_WORKER_MODE=pi
SYNC_HEARTBEAT_INTERVAL_SECONDS=5
SYNC_MASTER_CADENCE_SECONDS=300
SYNC_OPERATIONAL_CADENCE_SECONDS=5
SYNC_AR_CADENCE_SECONDS=300
SYNC_DOCUMENT_CADENCE_SECONDS=300
SYNC_BATCH_SIZE=1000
MIRROR_STAGING_SCHEMA=public
DB_USE_NULL_POOL=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300

# Dispatch / GPS enrichment
GPS_CSV_PATH=
LOGO_PATH=

# Samsara
SAMSARA_API_TOKEN=
SAMSARA_CACHE_TTL=15
SAMSARA_BRANCH_TAGS_JSON={}
SAMSARA_VEHICLE_BRANCH_MAP={}

# Credit image / email sync
EMAIL_ADDRESS=
EMAIL_PASSWORD=
IMAP_SERVER=outlook.office365.com
IMAP_PORT=993
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
